# GitHub OAuth App credentials for "Sign in with GitHub".
# Copy this file to `.env` (same directory) and fill in your values, then
# restart the app. `.env` is gitignored so your secret never gets committed.
#
# Create the OAuth App at https://github.com/settings/applications/new
# with Authorization callback URL exactly: http://127.0.0.1:8765/callback

# Copy the values EXACTLY as shown on the OAuth App page — do not add any prefix.
PRFLOW_GH_CLIENT_ID=your_client_id_here
PRFLOW_GH_CLIENT_SECRET=your_client_secret_here
